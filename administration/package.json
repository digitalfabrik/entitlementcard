  "devDependencies": {
    "@babel/runtime": "^7.29.2",
    "@bufbuild/buf": "^1.67.0",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@eslint/compat": "^2.0.4",
    "@eslint/eslintrc": "^3.3.1",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typed-document-node": "^6.1.7",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@jest/globals": "^30.2.0",
    "@parcel/watcher": "^2.5.6",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.2",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.1",
    "eslint": "^9.39.4",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-jsx-expressions": "^1.3.2",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.0",
    "ts-jest": "^29.4.9",
    "ts-jest-mock-import-meta": "^1.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.6",
    "vite-plugin-generate-file": "^0.3.1"
  },
  "scripts": {
    "build": "vite build",
    "codegen:gql": "graphql-codegen --config graphql-codegen.ts",
    "codegen:gql:dev": "graphql-codegen --config graphql-codegen.ts --watch",
    "codegen:pb": "buf generate",
    "check-circular-deps": "bash ./scripts/check_circular_deps.sh",
    "format": "eslint . --fix && prettier . --write",
    "lint": "eslint . && prettier . --check",
    "postinstall": "npm run codegen:pb && npm run codegen:gql",
    "start": "concurrently 'npm run start:dev' 'npm run codegen:gql:dev'",
    "start:dev": "vite --open",
    "start:ci": "vite --open=false",
    "test": "jest",
    "test:e2e": "npx playwright test",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watchAll",
    "ts:check": "tsc --build"
  },
  "madge": {
    "excludeRegExp": [
      "^project-configs\\/index\\.ts$",
      "^project-configs\\/bayern\\/config\\.ts$"
    ],
    "detectiveOptions": {
      "ts": {
        "skipTypeImports": true
      },
      "tsx": {
        "skipTypeImports": true
      }
    }
  }
}
